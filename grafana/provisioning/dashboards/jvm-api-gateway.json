{
  "uid": "jvm-api-gateway",
  "title": "JVM & API Gateway Overview",
  "tags": [
    "jvm",
    "api-gateway",
    "prometheus"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "JVM Heap Memory (Used vs Max)",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{application}} used"
        },
        {
          "refId": "B",
          "expr": "sum by (application) (jvm_memory_max_bytes{area=\"heap\"})",
          "legendFormat": "{{application}} max"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "JVM Non-Heap Memory (Used vs Max)",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (application) (jvm_memory_used_bytes{area=\"nonheap\"})",
          "legendFormat": "{{application}} used"
        },
        {
          "refId": "B",
          "expr": "sum by (application) (jvm_memory_max_bytes{area=\"nonheap\"})",
          "legendFormat": "{{application}} max"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "GC Pause Avg (ms)",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(jvm_gc_pause_seconds_sum[5m]) / rate(jvm_gc_pause_seconds_count[5m]) * 1000",
          "legendFormat": "avg pause"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GC Pause Rate (events/sec)",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (application) (rate(jvm_gc_pause_seconds_count[5m]))",
          "legendFormat": "{{application}}"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM Live Threads",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_threads_live_threads",
          "legendFormat": "{{application}}"
        }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "API Gateway Request Rate (req/s)",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"api-gateway\"}[5m]))",
          "legendFormat": "api-gateway"
        }
      ],
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "API Gateway Error Rate (%)",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"api-gateway\",status=~\"4..|5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{application=\"api-gateway\"}[5m])) * 100",
          "legendFormat": "error %"
        }
      ],
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "API Gateway Avg Latency (ms)",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_sum{application=\"api-gateway\"}[5m])) / sum(rate(http_server_requests_seconds_count{application=\"api-gateway\"}[5m])) * 1000",
          "legendFormat": "avg latency"
        }
      ],
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "API Gateway P95 Latency (ms)",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"api-gateway\"}[5m]))) * 1000",
          "legendFormat": "p95 latency"
        }
      ],
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 }
    }
  ],
  "templating": {
    "list": []
  }
}
